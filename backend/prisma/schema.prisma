// Prisma schema for Disc Golf Putting League
// Supports arbitrary divisions, holes, rounds, seasons, and league nights

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── App Settings (singleton row, id = 1) ─────────────────────────────────────

model Settings {
  id            Int     @id @default(1)
  housePerEntry Float   @default(1)
  eoyPerEntry   Float   @default(2)
  leagueInfoMd  String?
}

// ─── Auth & Users ─────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  firstName      String?
  lastName       String?
  suffix         String?
  phone                String?
  hasAcknowledgedInfo  Boolean  @default(false)
  isAdmin              Boolean  @default(false)
  passwordHash   String?
  avatarDataUrl  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tokens                 MagicLinkToken[]
  player                 Player?
  scorekeeperAssignments ScorekeeperAssignment[]
  scoreAuditLogs         ScoreAuditLog[]
  forumPosts             ForumPost[]
  forumComments          ForumComment[]
  forumReactions         ForumReaction[]
  notificationPreference NotificationPreference?
  pendingDigestItems     PendingDigestItem[]
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── League Structure ──────────────────────────────────────────────────────────

model Division {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  entryFee    Float    @default(8)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  players     Player[]
  checkIns    CheckIn[]
}

model Player {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  divisionId  String?
  division    Division? @relation(fields: [divisionId], references: [id])
  pdgaNumber  String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  scores               Score[]
  putOffParticipations PuttOffParticipant[]
  checkIns             CheckIn[]
  cardPlayers          CardPlayer[]
  scorekeeperCards     Card[]              @relation("CardScorekeeper")
}

model Season {
  id          String      @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  leagueNights LeagueNight[]
}

model LeagueNight {
  id             String         @id @default(cuid())
  seasonId       String
  season         Season         @relation(fields: [seasonId], references: [id])
  date           DateTime
  status         LeagueStatus   @default(SCHEDULED)
  tieBreakerMode TieBreakerMode @default(SPLIT)
  notes          String?
  cardsPublished Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  holes                  Hole[]
  rounds                 Round[]
  scorekeeperAssignments ScorekeeperAssignment[]
  puttOffs               PuttOff[]
  checkIns               CheckIn[]
  cards                  Card[]
  scoreAuditLogs         ScoreAuditLog[]
  forumPosts             ForumPost[]
}

enum LeagueStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TieBreakerMode {
  SPLIT
  PUTT_OFF
}

// ─── Check-ins ─────────────────────────────────────────────────────────────────

model CheckIn {
  id            String      @id @default(cuid())
  leagueNightId String
  leagueNight   LeagueNight @relation(fields: [leagueNightId], references: [id], onDelete: Cascade)
  playerId      String
  player        Player      @relation(fields: [playerId], references: [id])
  divisionId    String?
  division      Division?   @relation(fields: [divisionId], references: [id])
  checkedInAt   DateTime    @default(now())
  checkedInBy   String?     // userId of admin who checked them in
  hasPaid       Boolean     @default(false)

  @@unique([leagueNightId, playerId])
}

// ─── Cards (player groups) ─────────────────────────────────────────────────────

model Card {
  id            String      @id @default(cuid())
  leagueNightId String
  leagueNight   LeagueNight @relation(fields: [leagueNightId], references: [id], onDelete: Cascade)
  name          String      // "Card 1", "Card A", etc.
  startingHole  Int         @default(1)
  scorekeeperId String?
  scorekeeper   Player?     @relation("CardScorekeeper", fields: [scorekeeperId], references: [id])
  createdAt     DateTime    @default(now())

  players       CardPlayer[]
}

model CardPlayer {
  id        String  @id @default(cuid())
  cardId    String
  card      Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player  @relation(fields: [playerId], references: [id])
  sortOrder Int     @default(0)
  hasLeft   Boolean @default(false)

  @@unique([cardId, playerId])
}

// ─── Holes & Rounds ────────────────────────────────────────────────────────────

model Hole {
  id            String      @id @default(cuid())
  leagueNightId String
  leagueNight   LeagueNight @relation(fields: [leagueNightId], references: [id], onDelete: Cascade)
  number        Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  scores        Score[]

  @@unique([leagueNightId, number])
}

model Round {
  id            String      @id @default(cuid())
  leagueNightId String
  leagueNight   LeagueNight @relation(fields: [leagueNightId], references: [id], onDelete: Cascade)
  number        Int
  isComplete    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  scores        Score[]

  @@unique([leagueNightId, number])
}

// ─── Scoring ───────────────────────────────────────────────────────────────────

model Score {
  id         String   @id @default(cuid())
  playerId   String
  player     Player   @relation(fields: [playerId], references: [id])
  holeId     String
  hole       Hole     @relation(fields: [holeId], references: [id])
  roundId    String
  round      Round    @relation(fields: [roundId], references: [id])
  position   Position
  made       Int
  bonus      Boolean  @default(false)
  enteredBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  auditLogs  ScoreAuditLog[]

  @@unique([playerId, holeId, roundId, position])
}

enum Position {
  SHORT
  LONG
}

// ─── Score Audit Log ───────────────────────────────────────────────────────────

model ScoreAuditLog {
  id            String      @id @default(cuid())
  leagueNightId String
  leagueNight   LeagueNight @relation(fields: [leagueNightId], references: [id], onDelete: Cascade)
  scoreId       String
  score         Score       @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  // Denormalized so audit records stay readable even if underlying data changes
  userName      String
  playerName    String
  holeNum       Int
  roundNum      Int
  position      Position
  prevMade      Int?        // null = first-time entry (no prior value)
  newMade       Int
  createdAt     DateTime    @default(now())
}

// ─── Scorekeeper Assignments ───────────────────────────────────────────────────

model ScorekeeperAssignment {
  id            String      @id @default(cuid())
  leagueNightId String
  leagueNight   LeagueNight @relation(fields: [leagueNightId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  holeNumbers   Int[]
  createdAt     DateTime    @default(now())

  @@unique([leagueNightId, userId])
}

// ─── Tie-Breaker Putt-Offs ────────────────────────────────────────────────────

model PuttOff {
  id            String      @id @default(cuid())
  leagueNightId String
  leagueNight   LeagueNight @relation(fields: [leagueNightId], references: [id])
  divisionId    String
  round         Int         @default(1)
  winnerId      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  participants  PuttOffParticipant[]
}

model PuttOffParticipant {
  id         String  @id @default(cuid())
  puttOffId  String
  puttOff    PuttOff @relation(fields: [puttOffId], references: [id], onDelete: Cascade)
  playerId   String
  player     Player  @relation(fields: [playerId], references: [id])
  round      Int     @default(1)
  made       Int
  bonus      Boolean @default(false)

  @@unique([puttOffId, playerId, round])
}

// ─── Message of the Week ──────────────────────────────────────────────────────

model Motw {
  id        String   @id @default(cuid())
  title     String?
  body      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Motd")
}

// ─── Notification Preferences ─────────────────────────────────────────────────

enum ForumNotifyMode {
  ALL        // all forum activity (posts, comments, reactions by anyone)
  OWN_POSTS  // activity on posts/comments the user authored
  ENGAGED    // activity on posts the user commented on or reacted to
  NONE       // no forum email notifications
}

enum DigestMode {
  IMMEDIATE  // send each notification as it happens
  DAILY      // batch into a once-per-day digest
}

model NotificationPreference {
  id               String          @id @default(cuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  forumMode        ForumNotifyMode @default(OWN_POSTS)
  digestMode       DigestMode      @default(IMMEDIATE)
  lastDigestSentAt DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model PendingDigestItem {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType        String
  postId           String
  postTitle        String
  actorName        String
  eventDescription String
  createdAt        DateTime @default(now())
}

// ─── Forum ─────────────────────────────────────────────────────────────────────

enum ForumEmoji {
  LIKE
  FIRE
  LAUGH
}

model ForumPost {
  id            String       @id @default(cuid())
  authorId      String
  author        User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  leagueNightId String?
  leagueNight   LeagueNight? @relation(fields: [leagueNightId], references: [id], onDelete: Cascade)
  title         String
  body          String
  editedAt      DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  comments  ForumComment[]
  reactions ForumReaction[]
}

model ForumComment {
  id        String    @id @default(cuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  editedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  reactions ForumReaction[]
}

// postId XOR commentId — enforced by partial unique indexes added manually in migration SQL
model ForumReaction {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     ForumEmoji
  postId    String?
  post      ForumPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId String?
  comment   ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())
}
